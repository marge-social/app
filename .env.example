# --- Base de données ---
DATABASE_URL="postgresql://user@localhost:5432/marge"

# --- Instance ---
# Domaine public de l'instance (sans slash final). En dev : localhost:3000.
# Dès la fédération, pointer vers un tunnel public (ngrok/cloudflared).
APP_URL="http://localhost:3000"
INSTANCE_DOMAIN="localhost:3000"

# --- Secrets ---
# Clé de chiffrement (AES-256) des clés privées des acteurs. 32 octets en hex.
# Générer : openssl rand -hex 32
KEY_ENCRYPTION_SECRET=""
# Secret protégeant l'endpoint cron de polling RSS.
CRON_SECRET=""
