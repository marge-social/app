# --- Base de données ---
DATABASE_URL="postgresql://user@localhost:5432/marge"

# --- Instance ---
# Domaine public de l'instance (sans slash final). En dev : localhost:3000.
# Dès la fédération, pointer vers un tunnel public (ngrok/cloudflared).
APP_URL="http://localhost:3000"
INSTANCE_DOMAIN="localhost:3000"

# --- Secrets ---
# Clé de chiffrement (AES-256) des clés privées des acteurs. 32 octets en hex.
# Générer : openssl rand -hex 32
KEY_ENCRYPTION_SECRET=""
# Secret protégeant les endpoints cron (polling RSS, digest, maintenance des
# inscriptions). Header `Authorization: Bearer <secret>` ou `?secret=`.
CRON_SECRET=""

# --- Email transactionnel (activation d'inscription, cf. ADR 0006) ---
# Transport SMTP via nodemailer. Laisser SMTP_HOST vide en dev = transport
# « journal » : l'email n'est pas envoyé, le lien d'activation s'affiche dans la
# console du serveur (suffisant pour dérouler tout le flux en local).
SMTP_HOST=""
SMTP_PORT="587"
# true ⇒ TLS implicite (port 465) ; false ⇒ STARTTLS (587/25).
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
# Adresse d'expéditeur des emails (ex. "Marge <no-reply@marge.social>").
MAIL_FROM=""

# --- Stockage objet (médias) ---
# En dev, on peut laisser MEDIA_BASE_URL vide (fallback APP_URL/media) et ne pas
# configurer S3 : l'upload n'aboutira pas, mais la validation (type/taille/EXIF)
# reste testable. Pour un test S3 réel, renseigner les clés du bucket OVH.
MEDIA_BASE_URL=""
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# OVH peut exiger le path-style selon la région ("true"/"false").
S3_FORCE_PATH_STYLE="false"

# --- Mesure d'audience (Matomo) ---
# Suivi RGPD sans bandeau (sans cookie, respect DNT, chemin seul). Laisser vide
# en dev = aucun suivi. Penser à activer côté serveur Matomo : anonymisation
# d'IP (≥ 2 octets) + respect du Do Not Track.
MATOMO_URL=""
MATOMO_SITE_ID=""
