# Copier en .env sur le VPS et remplir. NE PAS committer le .env réel.

# --- Domaine public (un enregistrement DNS A doit pointer vers l'IP du VPS) ---
DOMAIN=marge.exemple.org
ACME_EMAIL=toi@exemple.org

# --- PostgreSQL (le service `db` du compose) ---
POSTGRES_PASSWORD=remplace-par-un-mot-de-passe-fort
DATABASE_URL=postgresql://marge:remplace-par-un-mot-de-passe-fort@db:5432/marge

# --- Instance (DOIT correspondre à DOMAIN, en https) ---
# ⚠️ Stable et définitif : les URI d'acteurs fédérés en dépendent.
APP_URL=https://marge.exemple.org
INSTANCE_DOMAIN=marge.exemple.org

# --- Secrets (générer : openssl rand -hex 32) ---
# ⚠️ KEY_ENCRYPTION_SECRET ne doit JAMAIS changer après le 1er compte créé,
# sinon les clés privées des acteurs deviennent indéchiffrables.
KEY_ENCRYPTION_SECRET=
CRON_SECRET=

# --- Stockage objet médias (OVH Object Storage, S3) — cf. DEPLOY.md ---
# Sous-domaine public servant les médias (DNS `media` → IP du VPS). Caddy le
# reverse-proxy vers le bucket (bloc `{$MEDIA_DOMAIN}` du Caddyfile).
MEDIA_DOMAIN=media.marge.exemple.org
MEDIA_BASE_URL=https://media.marge.exemple.org
# Hôte S3 du bucket (réécrit par Caddy comme en-tête Host vers le bucket).
MEDIA_BUCKET_HOST=marge-media.s3.gra.io.cloud.ovh.net
# Connexion S3 (clés générées côté OVH).
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_BUCKET=marge-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# --- Mesure d'audience (Matomo) — RGPD sans bandeau ---
# Suivi sans cookie, respectant Do Not Track, n'envoyant que le chemin (pas la
# query string). Laisser vide pour désactiver. ⚠️ Activer AUSSI côté serveur
# Matomo (requis pour l'exemption CNIL de bandeau) : anonymisation d'IP
# (≥ 2 octets) + respect du Do Not Track. Mentionner la mesure dans une page
# « vie privée / mentions légales ».
MATOMO_URL=https://analytics.kilometre-0.fr
MATOMO_SITE_ID=10
