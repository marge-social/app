# HTTPS automatique (Let's Encrypt) + reverse proxy vers l'app.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip
	# Plafond de taille de corps : rejette tôt les envois > 5 Mo (cahier médias
	# §3.3), avec une marge pour l'overhead multipart.
	request_body {
		max_size 6MB
	}
	# Transmet l'hôte public et le schéma à l'app. Caddy le fait par défaut,
	# mais on l'explicite : Fedify s'appuie sur l'origine canonique (cf. option
	# `origin` du Federation) et, à défaut, sur ces en-têtes du reverse proxy.
	reverse_proxy app:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Origine média séparée (cahier médias §2) : reverse-proxy le bucket S3 OVH en
# réécrivant l'en-tête Host. Sort le VPS du chemin des fichiers et isole tout
# contenu des cookies/session de l'app. MEDIA_BUCKET_HOST = hôte S3 du bucket
# (ex. marge-media.s3.gra.io.cloud.ovh.net).
#
# IMPORTANT : valeurs de repli en `.localhost` si MEDIA_DOMAIN/MEDIA_BUCKET_HOST
# ne sont pas définis. Sans ça, un `{$MEDIA_DOMAIN}` vide produit un bloc SANS
# adresse → Caddy le prend pour un bloc d'options globales mal placé → toute la
# config est rejetée → Caddy en crash-loop → site principal HORS LIGNE. Le repli
# `.localhost` (certificat interne, jamais joignable publiquement, aucun ACME)
# garde la config valide ; renseigner les deux variables active réellement
# l'origine média (cf. DEPLOY.md §2 ter).
{$MEDIA_DOMAIN:media.localhost} {
	encode zstd gzip
	reverse_proxy https://{$MEDIA_BUCKET_HOST:localhost} {
		header_up Host {$MEDIA_BUCKET_HOST:localhost}
	}
}
