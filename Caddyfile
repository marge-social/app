# HTTPS automatique (Let's Encrypt) + reverse proxy vers l'app.
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip
	# Transmet l'hôte public et le schéma à l'app. Caddy le fait par défaut,
	# mais on l'explicite : Fedify s'appuie sur l'origine canonique (cf. option
	# `origin` du Federation) et, à défaut, sur ces en-têtes du reverse proxy.
	reverse_proxy app:3000 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}
